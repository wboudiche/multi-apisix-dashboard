<?xml version="1.0"?>
<wsdl:definitions xmlns:wsdl="http://schemas.xmlsoap.org/wsdl/"
  xmlns:soap12="http://schemas.xmlsoap.org/wsdl/soap12/" name="BillingService">
  <wsdl:binding name="BillingBinding" type="tns:BillingPort">
    <soap12:binding transport="http://schemas.xmlsoap.org/soap/http"/>
    <wsdl:operation name="GetInvoice">
      <soap12:operation soapAction="urn:GetInvoice"/>
    </wsdl:operation>
    <wsdl:operation name="PayInvoice">
      <soap12:operation soapAction="urn:PayInvoice"/>
    </wsdl:operation>
  </wsdl:binding>
  <wsdl:service name="BillingService">
    <wsdl:port name="BillingPort" binding="tns:BillingBinding">
      <soap12:address location="http://billing-soap:8080/services/Billing"/>
    </wsdl:port>
  </wsdl:service>
</wsdl:definitions>
